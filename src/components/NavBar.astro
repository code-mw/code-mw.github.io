---
const tabs = [
  { id: 'about', label: 'About' },
];
---

<nav id="site-nav" aria-label="Section navigation">
  <div class="nav-inner">
    {tabs.map(tab => (
      <a href={`#${tab.id}`} class="nav-tab" data-tab={tab.id}>
        {tab.label}
      </a>
    ))}
  </div>
</nav>

<style>
  #site-nav {
    position: sticky;
    top: 25svh;
    z-index: 9;
    background: white;
    border-bottom: 1px solid var(--color-gray-200);
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  #site-nav.visible {
    opacity: 1;
  }

  @media (prefers-color-scheme: dark) {
    #site-nav {
      background: var(--color-slate-950);
      border-bottom-color: var(--color-slate-800);
    }
  }

  .nav-inner {
    max-width: 42rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
  }

  .nav-tab {
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-gray-500);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.2s, border-color 0.2s;
  }

  .nav-tab:hover {
    color: var(--color-gray-900);
  }

  .nav-tab.active {
    color: var(--color-blue-600);
    border-bottom-color: var(--color-blue-600);
  }

  @media (prefers-color-scheme: dark) {
    .nav-tab:hover {
      color: white;
    }

    .nav-tab.active {
      color: var(--color-blue-400);
      border-bottom-color: var(--color-blue-400);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #site-nav {
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll<HTMLAnchorElement>('.nav-tab');

    const activate = (id: string) => {
      tabs.forEach(tab => {
        tab.classList.toggle('active', tab.dataset.tab === id);
      });
    };

    // Default active tab
    activate('about');

    // Update active on click
    tabs.forEach(tab => {
      tab.addEventListener('click', () => activate(tab.dataset.tab ?? ''));
    });
  });
</script>
