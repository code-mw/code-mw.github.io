---
interface Props {
  paragraphs: string[];
}
const { paragraphs } = Astro.props;
---

<section id="about" class="max-w-2xl mx-auto px-6 py-16">
  <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">About</h2>
  {paragraphs.map((paragraph) => (
    <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-6 last:mb-0">
      {paragraph}
    </p>
  ))}
</section>
