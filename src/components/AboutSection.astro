---
interface Props {
  paragraphs: string[];
}
const { paragraphs } = Astro.props;
---

<section id="about" class="site-container py-16">
  <h2 class="section-heading text-gray-900 dark:text-white mb-4">About</h2>
  {paragraphs.map((paragraph) => (
    <p class="about-body text-gray-600 dark:text-gray-400 leading-relaxed mb-6 last:mb-0">
      {paragraph}
    </p>
  ))}
</section>

<style>
  .about-body {
    font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
    max-width: 65ch;
  }
</style>
